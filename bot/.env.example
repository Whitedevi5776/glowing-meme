# ─── Required ──────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
OWNER_ID=your_telegram_user_id_here

# ─── Database ──────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/pappybot
REDIS_URL=redis://localhost:6379

# ─── WhatsApp Owner Number (for group PFP tasks) ──────────
OWNER_WA_NUMBER=

# ─── Optional ──────────────────────────────────────────────
SESSION_SECRET=change_this_to_a_random_secret_string
NODE_ENV=production
LOG_LEVEL=info

# ─── Channels ─────────────────────────────────────────────
TELEGRAM_CHANNEL=
WHATSAPP_CHANNEL=

# ─── Wallpaper Sources (optional API keys) ────────────────
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=
